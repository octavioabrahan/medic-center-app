generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Persona {
  cedula     String  @id
  nombre     String
  apellido   String
  email      String
  telefono   String

  profesional     Profesional?
  hijos           Hijo[]
  personaRoles    PersonaRol[]
  agendamientos   Agendamiento[]

  @@map("personas")
}

model Profesional {
  profesional_id   String   @id @default(uuid())
  cedula           String   @unique
  especialidad_id  String

  persona          Persona  @relation(fields: [cedula], references: [cedula])
  especialidad     Especialidad @relation(fields: [especialidad_id], references: [especialidad_id])
  horarios         HorarioMedico[]
  excepciones      HorarioExcepcion[]
  agendamientos    Agendamiento[]

  @@map("profesionales")
}

model Especialidad {
  especialidad_id  String @id @default(uuid())
  nombre           String
  tipo_atencion_id Int

  profesionales    Profesional[]
  agendamientos    Agendamiento[]

  tipoAtencion     TipoAtencion @relation(fields: [tipo_atencion_id], references: [tipo_atencion_id])

  @@map("especialidades")
}

model TipoAtencion {
  tipo_atencion_id Int    @id @default(autoincrement())
  nombre           String
  especialidades   Especialidad[]
  agendamientos    Agendamiento[]

  @@map("tipo_atencion")
}

model Agendamiento {
  agendamiento_id  Int      @id @default(autoincrement())
  created_at       DateTime @default(now())
  convenio         Boolean
  fecha_agendada   DateTime
  status           String   @default("pendiente")

  profesional_id   String
  especialidad_id  String
  tipo_atencion_id Int
  cedula           String

  profesional      Profesional   @relation(fields: [profesional_id], references: [profesional_id])
  especialidad     Especialidad  @relation(fields: [especialidad_id], references: [especialidad_id])
  tipo_atencion    TipoAtencion  @relation(fields: [tipo_atencion_id], references: [tipo_atencion_id])
  paciente         Persona       @relation(fields: [cedula], references: [cedula])

  @@map("agendamiento")
}

model HorarioMedico {
  horario_id     Int      @id @default(autoincrement())
  profesional_id String
  dia_semana     Int
  hora_inicio    String
  hora_termino   String
  valido_desde   DateTime
  valido_hasta   DateTime

  profesional    Profesional @relation(fields: [profesional_id], references: [profesional_id])

  @@map("horario_medico")
}

model HorarioExcepcion {
  excepcion_id    Int      @id @default(autoincrement())
  profesional_id  String
  fecha           DateTime
  estado          String

  profesional     Profesional @relation(fields: [profesional_id], references: [profesional_id])

  @@map("horario_excepciones")
}

model Hijo {
  cedula_hijo    String @id
  nombre_hijo    String
  apellidos_hijo String
  sexo           Boolean
  fecha_nac_hijo DateTime
  cedula         String

  representante  Persona @relation(fields: [cedula], references: [cedula])

  @@map("hijos")
}

model Rol {
  rol_id   Int    @id @default(autoincrement())
  nombre   String
  personas PersonaRol[]

  @@map("roles")
}

model PersonaRol {
  id         Int     @id @default(autoincrement())
  cedula     String
  rol_id     Int

  persona    Persona @relation(fields: [cedula], references: [cedula])
  rol        Rol     @relation(fields: [rol_id], references: [rol_id])

  @@map("persona_roles")
}
